{
  "name": "aria-bridge-launcher",
  "version": "1.0.0",
  "description": "Launcher for Aria Bridge",
  "author": "Anthony-Haber",
  "repository": {
    "type": "git",
    "url": "https://github.com/Music-Intelligence-Lab/Aria-Bridge.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win zip",
    "build:mac": "electron-builder --mac zip"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.aria.bridge",
    "productName": "Aria Launcher",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": "zip",
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "../dist/aria_backend.exe",   "to": "aria_backend.exe",   "filter": ["**"] },
        { "from": "../dist/Aria Bridge.exe",    "to": "Aria Bridge.exe",    "filter": ["**"] },
        { "from": "../dist/Aria Bridge.vst3",   "to": "Aria Bridge.vst3",   "filter": ["**"] }
      ]
    },
    "mac": {
      "target": "zip",
      "artifactName": "AriaLauncher-mac.zip",
      "extraResources": [
        { "from": "../dist/aria_backend",    "to": "aria_backend",    "filter": ["**"] },
        { "from": "../dist/Aria Bridge.app", "to": "Aria Bridge.app", "filter": ["**"] },
        { "from": "../dist/Aria Bridge.vst3","to": "Aria Bridge.vst3","filter": ["**"] }
      ]
    }
  }
}
